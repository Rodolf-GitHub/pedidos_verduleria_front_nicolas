  "components": {
    "schemas": {
      "Input": {
        "properties": {
          "limit": {
            "default": 100,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "default": 0,
            "minimum": 0,
            "title": "Offset",
            "type": "integer"
          }
        },
        "title": "Input",
        "type": "object"
      },
      "PagedProductoSchema": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProductoSchema"
            },
            "title": "Items",
            "type": "array"
          },
          "count": {
            "title": "Count",
            "type": "integer"
          }
        },
        "required": ["items", "count"],
        "title": "PagedProductoSchema",
        "type": "object"
      },
      "ProductoSchema": {
        "properties": {
          "precio_venta": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Venta"
          },
          "actualizado_recientemente": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Actualizado Recientemente"
          },
          "precio_compra_unitario": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Compra Unitario"
          },
          "id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "ID"
          },
          "nombre": {
            "maxLength": 100,
            "title": "Nombre",
            "type": "string"
          },
          "se_vende_en_unidad_medida": {
            "anyOf": [
              {
                "maxLength": 50,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "cajas",
            "title": "Se Vende En Unidad Medida"
          },
          "se_pide_en_unidad_medida": {
            "anyOf": [
              {
                "maxLength": 50,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "kg",
            "title": "Se Pide En Unidad Medida"
          },
          "precio_compra": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": 100,
            "title": "Precio Compra"
          },
          "factor_division": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": 1,
            "title": "Factor Division"
          },
          "ganancia_porcentaje": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": 40,
            "title": "Ganancia Porcentaje"
          },
          "imagen": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Imagen"
          },
          "ultima_actualizacion": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ultima Actualizacion"
          }
        },
        "required": ["nombre"],
        "title": "ProductoSchema",
        "type": "object"
      },
      "ProductoCreateSchema": {
        "properties": {
          "nombre": {
            "title": "Nombre",
            "type": "string"
          },
          "se_vende_en_unidad_medida": {
            "anyOf": [
              {
                "enum": [
                  "kg",
                  "unidades",
                  "litros",
                  "otros",
                  "atados",
                  "cajas",
                  "sacos",
                  "bandejas",
                  "planchas"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "kg",
            "title": "Se Vende En Unidad Medida"
          },
          "se_compra_en_unidad_medida": {
            "anyOf": [
              {
                "enum": [
                  "kg",
                  "unidades",
                  "litros",
                  "otros",
                  "atados",
                  "cajas",
                  "sacos",
                  "bandejas",
                  "planchas"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "kg",
            "title": "Se Compra En Unidad Medida"
          },
          "factor_division": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": 1,
            "title": "Factor Division"
          },
          "precio_compra": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": 100,
            "title": "Precio Compra"
          },
          "ganancia_porcentaje": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": 40,
            "title": "Ganancia Porcentaje"
          }
        },
        "required": ["nombre"],
        "title": "ProductoCreateSchema",
        "type": "object"
      },
      "ProductoUpdateSchema": {
        "properties": {
          "nombre": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Nombre"
          },
          "se_vende_en_unidad_medida": {
            "anyOf": [
              {
                "enum": [
                  "kg",
                  "unidades",
                  "litros",
                  "otros",
                  "atados",
                  "cajas",
                  "sacos",
                  "bandejas",
                  "planchas"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Se Vende En Unidad Medida"
          },
          "precio_compra": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Compra"
          },
          "ganancia_porcentaje": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ganancia Porcentaje"
          },
          "factor_division": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Factor Division"
          },
          "se_compra_en_unidad_medida": {
            "anyOf": [
              {
                "enum": [
                  "kg",
                  "unidades",
                  "litros",
                  "otros",
                  "atados",
                  "cajas",
                  "sacos",
                  "bandejas",
                  "planchas"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Se Compra En Unidad Medida"
          }
        },
        "title": "ProductoUpdateSchema",
        "type": "object"
      }
    },
    "securitySchemes": {
      "AuthBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
