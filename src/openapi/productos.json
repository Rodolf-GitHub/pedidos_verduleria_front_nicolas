        "operationId": "producto_api_listar_productos",
        "summary": "Listar Productos",
        "parameters": [
          {
            "in": "query",
            "name": "busqueda",
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Busqueda"
            },
            "required": false
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 100,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            },
            "required": false
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "Offset",
              "type": "integer"
            },
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedProductoSchema"
                }
              }
            }
          }
        },
        "tags": ["Productos"],
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    },
    "/api/productos/crear": {
      "post": {
        "operationId": "producto_api_crear_producto",
