        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductoSchema"
                }
              }
            }
          }
        },
        "tags": ["Productos"],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "properties": {
                  "imagen": {
                    "format": "binary",
                    "title": "Imagen",
                    "type": "string"
                  },
                  "payload": {
                    "$ref": "#/components/schemas/ProductoCreateSchema"
                  }
                },
                "title": "MultiPartBodyParams",
                "type": "object",
                "required": ["payload"]
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    },
    "/api/productos/actualizar/{producto_id}": {
      "put": {
        "operationId": "producto_api_actualizar_producto",
        "summary": "Actualizar Producto",
        "parameters": [
          {
            "in": "path",
            "name": "producto_id",
            "schema": {
              "title": "Producto Id",
              "type": "integer"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
