                }
              }
            }
          }
        },
        "tags": ["Productos"],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "properties": {
                  "imagen": {
                    "format": "binary",
                    "title": "Imagen",
                    "type": "string"
                  },
                  "payload": {
                    "$ref": "#/components/schemas/ProductoUpdateSchema"
                  }
                },
                "title": "MultiPartBodyParams",
                "type": "object",
                "required": ["payload"]
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    },
    "/api/productos/eliminar/{producto_id}": {
      "delete": {
        "operationId": "producto_api_eliminar_producto",
        "summary": "Eliminar Producto",
