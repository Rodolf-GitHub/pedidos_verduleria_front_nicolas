        ]
      }
    },
    "/api/pedidos_diarios/sin_completar": {
      "get": {
        "operationId": "pedido_diario_api_obtener_pedidos_diarios_sin_completar",
        "summary": "Obtener Pedidos Diarios Sin Completar",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/PedidosSinCompletarSchema"
                  },
                  "title": "Response",
                  "type": "array"
                }
              }
            }
          }
        },
        "description": "Devuelve la lista de fechas que tienen pedidos (compras) y cuyo pedido diario\n    no existe o no está marcado como 'completado'.\n\n🔒 **Permisos requeridos:** Comprador o Admin",
        "tags": ["Pedidos diarios"],
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
