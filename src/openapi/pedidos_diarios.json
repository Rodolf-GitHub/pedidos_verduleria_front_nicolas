    },
    "/api/pedidos_diarios/cambiar_estado": {
      "put": {
        "operationId": "pedido_diario_api_cambiar_estado_pedido_diario",
        "summary": "Cambiar Estado Pedido Diario",
        "parameters": [
          {
            "in": "query",
            "name": "fecha",
            "schema": {
              "title": "Fecha",
              "type": "string"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "description": "🔒 **Permisos requeridos:** Comprador o Admin",
        "tags": ["Pedidos diarios"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PedidoDiarioUpdateSchema"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "AuthBearer": []
          }
        ]
      }
    },
    "/api/pedidos_diarios/por_pedido/{pedido_id}": {
      "get": {
        "operationId": "pedido_diario_api_obtener_pedido_diario_por_pedido",
        "summary": "Obtener Pedido Diario Por Pedido",
        "parameters": [
          {
            "in": "path",
            "name": "pedido_id",
            "schema": {
              "title": "Pedido Id",
              "type": "integer"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PedidoDiarioSchema"
                }
              }
            }
          }
        },
        "description": "🔒 **Permisos requeridos:** Verdulero, Comprador o Admin",
