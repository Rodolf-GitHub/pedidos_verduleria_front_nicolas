  "components": {
    "schemas": {
      "PedidoDiarioCantidadNegocioSchema": {
        "properties": {
          "negocio_id": {
            "title": "Negocio Id",
            "type": "integer"
          },
          "negocio_nombre": {
            "title": "Negocio Nombre",
            "type": "string"
          },
          "cantidad": {
            "title": "Cantidad",
            "type": "number"
          },
          "unidad_medida": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Unidad Medida"
          }
        },
        "required": ["negocio_id", "negocio_nombre", "cantidad"],
        "title": "PedidoDiarioCantidadNegocioSchema",
        "type": "object"
      },
      "PedidoDiarioProductoSchema": {
        "properties": {
          "producto": {
            "$ref": "#/components/schemas/ProductoSchema"
          },
          "cantidades_por_negocio": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/PedidoDiarioCantidadNegocioSchema"
            },
            "title": "Cantidades Por Negocio",
            "type": "array"
          },
          "total": {
            "$ref": "#/components/schemas/PedidoDiarioUnidadSchema"
          }
        },
        "required": ["producto", "total"],
        "title": "PedidoDiarioProductoSchema",
        "type": "object"
      },
      "PedidoDiarioSchema": {
        "properties": {
          "fecha": {
            "title": "Fecha",
            "type": "string"
          },
          "estado": {
            "anyOf": [
              {
                "enum": ["en_proceso", "completado"],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Estado"
          },
          "items": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/PedidoDiarioProductoSchema"
            },
            "title": "Items",
            "type": "array"
          }
        },
        "required": ["fecha"],
        "title": "PedidoDiarioSchema",
        "type": "object"
      },
      "PedidoDiarioTotalPorUnidadSchema": {
        "properties": {
          "unidad_medida": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Unidad Medida"
          },
          "cantidad_total": {
            "title": "Cantidad Total",
            "type": "number"
          }
        },
        "required": ["cantidad_total"],
        "title": "PedidoDiarioTotalPorUnidadSchema",
        "type": "object"
      },
      "PedidoDiarioUnidadSchema": {
        "properties": {
          "unidad_pedido": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Unidad Pedido"
          },
          "totales_por_unidad": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/PedidoDiarioTotalPorUnidadSchema"
            },
            "title": "Totales Por Unidad",
            "type": "array"
          },
          "estado_compra": {
            "anyOf": [
              {
                "enum": ["comprado", "no_comprado"],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Estado Compra"
          },
          "precio_compra": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Compra"
          },
          "factor_division": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Factor Division"
          },
          "ganancia_aplicada": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ganancia Aplicada"
          },
          "motivo_no_compra": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Motivo No Compra"
          }
        },
        "title": "PedidoDiarioUnidadSchema",
        "type": "object"
      },
      "ProductoSchema": {
        "properties": {
          "precio_venta": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Venta"
          },
          "actualizado_recientemente": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Actualizado Recientemente"
          },
          "precio_compra_unitario": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Compra Unitario"
          },
          "id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "ID"
          },
          "nombre": {
            "maxLength": 100,
            "title": "Nombre",
            "type": "string"
          },
          "se_vende_en_unidad_medida": {
            "anyOf": [
              {
                "maxLength": 50,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "cajas",
            "title": "Se Vende En Unidad Medida"
          },
          "se_pide_en_unidad_medida": {
            "anyOf": [
              {
                "maxLength": 50,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": "kg",
            "title": "Se Pide En Unidad Medida"
          },
          "precio_compra": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": 100,
            "title": "Precio Compra"
          },
          "factor_division": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": 1,
            "title": "Factor Division"
          },
          "ganancia_porcentaje": {
            "anyOf": [
              {
                "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": 40,
            "title": "Ganancia Porcentaje"
          },
          "imagen": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Imagen"
          },
          "ultima_actualizacion": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ultima Actualizacion"
          }
        },
        "required": ["nombre"],
        "title": "ProductoSchema",
        "type": "object"
      },
      "PedidoDiarioEstadoUpdateSchema": {
        "properties": {
          "producto_id": {
            "title": "Producto Id",
            "type": "integer"
          },
          "estado_compra": {
            "enum": ["comprado", "no_comprado"],
            "title": "Estado Compra",
            "type": "string"
          },
          "motivo_no_compra": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Motivo No Compra"
          },
          "precio_compra": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Precio Compra"
          },
          "factor_division": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Factor Division"
          },
          "ganancia_aplicada": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ganancia Aplicada"
          }
        },
        "required": ["producto_id", "estado_compra"],
        "title": "PedidoDiarioEstadoUpdateSchema",
        "type": "object"
      },
      "PedidoDiarioUpdateSchema": {
        "properties": {
          "estado": {
            "enum": ["en_proceso", "completado"],
            "title": "Estado",
            "type": "string"
          }
        },
        "required": ["estado"],
        "title": "PedidoDiarioUpdateSchema",
        "type": "object"
      },
      "PedidosSinCompletarSchema": {
        "properties": {
          "fecha": {
            "title": "Fecha",
            "type": "string"
          },
          "urgencia": {
            "enum": ["sin_urgencia", "a_tiempo", "pendiente", "critico"],
            "title": "Urgencia",
            "type": "string"
          }
        },
        "required": ["fecha", "urgencia"],
        "title": "PedidosSinCompletarSchema",
        "type": "object"
      }
    },
    "securitySchemes": {
      "AuthBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "servers": []
}
